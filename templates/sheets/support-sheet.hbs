<form>
  <section class="character-sheet-front">
    {{> "systems/haunted/templates/sheets/partials/character-header.hbs"}}
    <div class="character-motive">
      {{#if (isdefined system.problem)}}
        <label class="attribute-label" for="system.problem">{{localize "HAUNTED.Character.Problem"}}:</label>
        <input type="text" name="system.problem" value="{{system.problem}}" data-dtype="String"/>
      {{/if}}
    </div>
    <div class="character-disposition">
        <div class="disposition-selection">
          <label class="attribute-label" for="system.disposition">{{localize "HAUNTED.Character.Disposition"}}:</label>
          <select class="disposition-choice" name="system.disposition" {{#if (gt system.disposition 0)}} disabled {{/if}}>
           {{selectOptions dispositionChoices selected=system.disposition valueAttr="key" labelAttr="label"}}
          </select>
        </div>
        {{#if (gt system.disposition 0)}}
          <div class="disposition-buttons">
            <button class="adjust-button adjust-button-label increase-disposition">+</button>
            <button class="adjust-button adjust-button-label decrease-disposition">-</button>
          </div>
        {{/if}}
  </div>
    <div class="attributes-support">
      {{> "systems/haunted/templates/sheets/partials/character-attributes.hbs"}}
    </div>
  </section>
  {{> "systems/haunted/templates/sheets/partials/character-notes.hbs"}}
</form>
