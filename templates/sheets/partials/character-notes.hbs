<section class="character-sheet-back">
  <label class="attribute-label">{{localize "HAUNTED.Character.Notes"}}</label>
  {{#if editable}}
    <prose-mirror
      name="system.notes"
      button="true"
      editable="{{editable}}"
      toggled="false"
      value="{{document.system.notes}}"
    >
      {{{notesHTML}}}
    </prose-mirror>
  {{else}}
    {{{notesHTML}}}
  {{/if}}
</section>